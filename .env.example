COREIOT_EMAIL=your_coreiot_email
COREIOT_PASSWORD=your_coreiot_password
COREIOT_DEVICE_ID=914ec000-24d4-11f1-8e7d-45cdb4e6c818

# faster-whisper settings
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=vi

# Piper settings
# Windows example: C:\\tools\\piper\\piper.exe
PIPER_PATH=piper
# Example: C:\\models\\piper\\en_US-lessac-medium.onnx
PIPER_MODEL=

# Optional local SLM response generation (Ollama)
LLM_ENABLED=false
LLM_BACKEND=ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
LLM_TEMPERATURE=0.8
LLM_TIMEOUT_SECONDS=15
