APP_NAME=Smart Home Dashboard API
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

COREIOT_EMAIL=your_coreiot_email
COREIOT_PASSWORD=your_coreiot_password
COREIOT_DEVICE_ID=914ec000-24d4-11f1-8e7d-45cdb4e6c818
COREIOT_BASE_URL=http://app.coreiot.io
COREIOT_TIMEOUT_SECONDS=10

# faster-whisper settings
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=vi

# Piper settings
# Example: /absolute/path/to/en_US-lessac-medium.onnx
PIPER_MODEL=

# Optional local SLM response generation (Ollama)
LLM_ENABLED=false
LLM_BACKEND=ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
LLM_TEMPERATURE=0.8
LLM_TIMEOUT_SECONDS=15

# API throttling
VOICE_RATE_LIMIT_COUNT=10
VOICE_RATE_LIMIT_WINDOW_SECONDS=60
DEVICE_RATE_LIMIT_COUNT=20
DEVICE_RATE_LIMIT_WINDOW_SECONDS=60

# Telemetry history
TELEMETRY_DEFAULT_HOURS=24
TELEMETRY_MAX_HOURS=72
TELEMETRY_LIMIT_POINTS=288
TELEMETRY_DEVICE_KEYS=temperature,humidity,ledState,servoAngle
