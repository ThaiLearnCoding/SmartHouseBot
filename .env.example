COREIOT_EMAIL=your_email
COREIOT_PASSWORD=your_password
COREIOT_DEVICE_ID=your_device_id

# faster-whisper settings
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=vi

# Piper settings
# Example: /Users/loibui/Downloads/2026/HCMUT/DADN/SmartHouseBot/vi_VN-vais1000-medium.onnx
PIPER_MODEL=/Users/loibui/Downloads/2026/HCMUT/DADN/SmartHouseBot/vi_VN-vais1000-medium.onnx

# Optional local SLM response generation (Ollama)
LLM_ENABLED=false
LLM_BACKEND=ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
LLM_TEMPERATURE=0.8
LLM_TIMEOUT_SECONDS=15
